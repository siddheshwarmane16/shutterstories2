datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  role         String          // "ADMIN" | "CLIENT"
  name         String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sentMessages Message[]       @relation("SentMessages")
  recvMessages Message[]       @relation("RecvMessages")
  blogs        Blog[]
  projects     ProjectStatus[]
}

model Category {
  id        String      @id @default(uuid())
  name      String      @unique
  slug      String      @unique
  items     Portfolio[]
}

model Portfolio {
  id          String    @id @default(uuid())
  title       String
  description String?
  mediaUrl    String
  mediaType   String    // "IMAGE" | "VIDEO"
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Service {
  id          String    @id @default(uuid())
  name        String    @unique
  description String
  imageUrl    String?
}

model Package {
  id          String    @id @default(uuid())
  name        String    // e.g. "Silver", "Gold", "Platinum", "Custom"
  price       Float
  description String
  features    String    // Semicolon-separated features list
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Booking {
  id            String          @id @default(uuid())
  eventType     String
  date          String
  location      String
  packageId     String
  package       Package         @relation(fields: [packageId], references: [id])
  requirements  String?
  contactName   String
  contactEmail  String
  contactPhone  String
  status        String          @default("PENDING") // "PENDING", "APPROVED", "IN_PROGRESS", "COMPLETED", "CANCELLED"
  createdAt     DateTime        @default(now())
  invoices      Invoice[]
  projectStatus ProjectStatus[]
}

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String
  clientRole  String?  // e.g. "Bride", "Groom", "CEO"
  rating      Int      @default(5)
  reviewText  String
  videoUrl    String?  // If they uploaded a video review
  avatarUrl   String?
  createdAt   DateTime @default(now())
}

model Blog {
  id            String   @id @default(uuid())
  title         String
  content       String   // Rich content
  featuredImage String
  category      String
  tags          String   // Comma-separated tags
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  seoTitle      String?
  seoDesc       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoice {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount    Float
  status    String   @default("UNPAID") // "UNPAID", "PAID"
  dueDate   String
  createdAt DateTime @default(now())
}

model ProjectStatus {
  id         String   @id @default(uuid())
  clientId   String
  client     User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  phase      String   @default("SHOOTING") // "SHOOTING", "EDITING", "COLOR_GRADING", "DELIVERED"
  percentage Int      @default(10)
  comments   String?
  deliverables String?  // Semicolon-separated URLs for client downloads
  updatedAt  DateTime @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("RecvMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())
}

model AnalyticsRecord {
  id          String   @id @default(uuid())
  metricName  String   // e.g. "VISITOR", "LEAD", "REVENUE"
  metricValue Float    @default(1.0)
  timestamp   DateTime @default(now())
}
